<%= render "layouts/navbar" %>
<div class="background-lists">
  <div class="d-flex justify-content-between p-4">
    <h2 class="text-light"> 🎞️ MOVIES </h2>
  </div>
  <div class="d-flex flex-wrap gap-3 m-2 p-4">
    <% @movies.each do |movie|%>
      <div class="card-movie">
        <%= image_tag movie.poster_url%>
        <div class="card-movie-infos">
          <div>
            <h2><%= movie.title%></h2>
            <p><%= truncate(movie.overview, length: 80) %></p>
          </div>

        </div>
          <div class="d-flex justify-content-around px-3">
            <div>
              🌟 <span class="text-light"><%= movie.rating%><span>
            </div>
            <div>
            <%= link_to new_movie_bookmark_path(movie), class: "link-offset-2 link-underline link-underline-opacity-0" do %>
              <i class="fa-solid fa-heart"></i>
            <% end %>
            </div>
          </div>

      </div>
    <% end %>
  </div>
</div>
