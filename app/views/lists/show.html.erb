<%= render "layouts/navbar" %>
<h2><%= @list.name%></h2>
<div class="d-flex flex-wrap gap-3 m-2">
<% if @bookmarks.empty?%>
  <p>There are no movies to display, start with adding a <%= link_to "new", new_list_bookmark_path(@list) %> one!</p>
<% else %>
  <% @bookmarks.each do |bookmark|%>
    <div class="card-movie">
      <%= image_tag bookmark.movie.poster_url%>
      <div class="card-movie-infos">
        <div>
          <h2><%= bookmark.movie.title%></h2>
          <p><%= truncate(bookmark.movie.overview, length: 80) %></p>
        </div>
        <div>
        ❝<%= bookmark.comment%>❞
        </div>
        <%= link_to bookmark_path(bookmark), data: {turbo_method: :delete, turbo_confirm: "Push it down the rabbit hole?"} do%>
          <i class="fa-solid fa-heart-crack"></i>
        <% end %>

      </div>
    </div>
  <% end %>

  <%= link_to "Add a new movie", new_list_bookmark_path(@list) %><br>
<% end %>
</div>
<%= link_to "Go back to your lists", lists_path%>
