<h2> 🗒️ Your lists </h2>
<% if @lists.empty?%>
  <p>There are no lists to display, start with creating a <%= link_to "new", new_list_path%> one!</p>
<% else %>
  <% @lists.each do |list|%>
    <%= list.name%> <%= link_to "More info", list_path(list)%>
  <% end %>
<% end %>
<%= link_to "Create a new list", new_list_path %>
<%= link_to "Go to all movies", movies_path %>
